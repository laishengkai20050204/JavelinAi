    "content" : "你能运行这个代码吗\n# schedule_makespan.py\n# -*- coding: utf-8 -*-\n\"\"\"\nMakespan-aware greedy UAV insertion (pred/succ only).\n- Truck graph: solid edges (1.csv), speed 50 km/h\n- Drone graph: solid + dashed (2.csv), speed 75 km/h\n- Demands: 3.csv (node -> kg); only nodes with q_u <= 50 are eligible for UAV\n- Single UAV, single flight at a time, max flight time 70 minutes\n- UAV must start/end at nodes on the truck route; service exactly one node u per sortie\n- Accept a sortie only if it reduces GLOBAL makespan:\n    new_makespan = max(new_truck_finish_time, UAV_finish_time) < current_makespan\n\"\"\"\n\nimport io\nimport math\nimport argparse\nfrom heapq import heappush, heappop\nimport pandas as pd\nimport numpy as np\n\n\n# ---------- Robust CSV parsers ----------\ndef parse_upper_tri_csv(path: str) -> pd.DataFrame:\n    \"\"\"Parse a distance-like matrix csv (may be upper-triangular).\n    Fills symmetric entries and sets diag=0. Index/cols -> '1'..'n' (str).\"\"\"\n    with open(path, \"r\", encoding=\"utf-8\") as f:\n        lines = [ln.strip(\"\\r\\n\") for ln in f.readlines()]\n    cleaned = []\n    for ln in lines:\n        if not ln.strip():\n            continue\n        if \",\" not in ln:\n            continue\n        cleaned.append(ln)\n    if not cleaned:\n        raise RuntimeError(f\"No CSV-looking lines in {path}\")\n    df = pd.read_csv(io.StringIO(\"\\n\".join(cleaned)), header=0)\n    # normalize headers\n    df.columns = [str(c).strip().replace(\"\\ufeff\", \"\") for c in df.columns]\n    # numeric\n    df = df.apply(pd.to_numeric, errors=\"coerce\")\n    n = df.shape[0]\n    df.index = [str(i + 1) for i in range(n)]\n    # symmetrize and zero diag\n    for i in range(n):\n        for j in range(n):\n            if i == j:\n                df.iat[i, j] = 0.0\n            else:\n                a = df.iat[i, j]\n                b = df.iat[j, i] if (j < df.shape[0] and i < df.shape[1]) else np.nan\n                if pd.isna(a) and not pd.isna(b):\n                    df.iat[i, j] = b\n                elif not pd.isna(a) and not pd.isna(b):\n                    df.iat[i, j] = min(a, b)\n    df.columns = [str(i + 1) for i in range(n)]\n    return df\n\n\ndef parse_demands_csv(path: str, n_nodes_guess=14) -> dict:\n    \"\"\"Parse demands in flexible formats: (node,demand) or a single row listing.\"\"\"\n    try:\n        df = pd.read_csv(path, header=0)\n        # case: explicit node/demand columns\n        node_col = None\n        demand_col = None\n        for c in df.columns:\n            low = str(c).strip().lower()\n            if low in (\"node\", \"节点\", \"点\", \"id\"):\n                node_col = c\n            if low in (\"demand\", \"需求\", \"需求kg\", \"q\", \"q_kg\"):\n                demand_col = c\n        if node_col and demand_col:\n            m = {}\n            for _, row in df.iterrows():\n                try:\n                    node = str(int(row[node_col]))\n                    val = float(row[demand_col])\n                    m[node] = val\n                except Exception:\n                    pass\n            return m\n        # case: two columns -> assume node,demand\n        if df.shape[1] == 2:\n            m = {}\n            for _, row in df.iterrows():\n                try:\n                    node = str(int(row.iloc[0]))\n                    val = float(row.iloc[1])\n                    m[node] = val\n                except Exception:\n                    pass\n            return m\n        # case: single row listing demands for 1..n\n        if df.shape[0] == 1 and df.shape[1] >= n_nodes_guess:\n            m = {}\n            for j in range(df.shape[1]):\n                m[str(j + 1)] = float(df.iloc[0, j])\n            return m\n    except Exception:\n        pass\n    # fallback empty\n    return {}\n\n\n# ---------- Graph & shortest paths ----------\ndef to_graph(df: pd.DataFrame) -> dict:\n    \"\"\"Adjacency dict with weights in km.\"\"\"\n    G = {}\n